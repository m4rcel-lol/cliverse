FROM golang:1.23-alpine AS builder
ARG VERSION=dev
WORKDIR /app
RUN apk add --no-cache git
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w -X main.version=${VERSION}" -o /worker ./cmd/worker

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
RUN adduser -D -u 1000 cliverse
WORKDIR /app
COPY --from=builder /worker /app/worker
RUN chown -R cliverse:cliverse /app
USER cliverse
ENTRYPOINT ["/app/worker"]
