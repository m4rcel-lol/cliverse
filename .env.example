# CLIverse Configuration

# Instance settings
DOMAIN=post.rbxl.eu
INSTANCE_NAME=CLIverse
INSTANCE_DESC=A CLIverse Fediverse instance

# Ports
SSH_PORT=6969
HTTP_PORT=8080

# Database
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_DSN=postgres://cliverse:changeme_strong_password@postgres:5432/cliverse?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# Security - generate with: openssl rand -hex 32
SESSION_SECRET=changeme-please-use-a-long-random-string-at-least-32-chars

# Admin password hash - generate with the bootstrap script
ADMIN_PASSWORD_HASH=

# Timeouts
SSH_IDLE_TIMEOUT=30m
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s

# Limits
MAX_CONNECTIONS=1000
MAX_POST_LENGTH=500
