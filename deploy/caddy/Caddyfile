{$DOMAIN} {
    reverse_proxy /users/* app:8080
    reverse_proxy /.well-known/webfinger app:8080
    reverse_proxy /.well-known/nodeinfo app:8080

    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        -Server
    }

    log {
        output stdout
    }
}
